{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "cd .. && npm install --include=optional && npm install --include=optional --workspace=athlete-tracker-client",
  "buildCommand": "cd .. && npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "../athlete-tracker-server/prisma/**"
    }
  },
  "rewrites": [
    { "source": "/api/v1/:path*", "destination": "/api" },
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
