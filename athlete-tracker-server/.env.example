# Variables de entorno — copiá a `.env` en esta carpeta

PORT=3000
NODE_ENV=development

# SQLite local (desarrollo)
DATABASE_URL="file:./dev.db"

# Obligatorio — usá un string largo y aleatorio en producción
JWT_SECRET=change-me-to-a-long-random-secret

# URL del frontend (CORS, links de reset de contraseña)
FRONTEND_URL=http://localhost:5173

# Producción en Vercel — Turso (SQLite serverless). No uses en local.
# TURSO_DATABASE_URL=libsql://...
# TURSO_AUTH_TOKEN=...
